# .dockerignore — keep build-context tight so docker layer cache stays effective.

# Build outputs
**/bin/
**/obj/
artifacts/

# IDE state
.vs/
.vscode/
.idea/
*.user
*.suo

# Git
.git/
.gitignore
.gitattributes
.github/

# Docs the runtime image doesn't need
*.md
docs/

# Test projects — runtime images don't ship them
tests/

# Local config
.env
.env.local
*.user
appsettings.*.local.json

# Signing key (production deployments materialize it via secret store, not bake-in)
build/*.snk
build/*.pfx
build/*.p12
build/*.cer
build/*.key

# Lock files / package caches
**/packages/
**/.nuget/
