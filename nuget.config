  </packageSources>
  <config>
    <add key="repositoryPath" value="./Packages" />
    <add key="globalPackagesFolder" value="./Packages" />
  </config>
  <settings>
    <repositoryPath>./Packages</repositoryPath>
  </settings>
</configuration>
